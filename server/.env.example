# ====== 서버 설정 ======
HOST=0.0.0.0
PORT=8000

# ====== Gemini 설정 ======
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=0.8
GEMINI_MAX_TOKENS=2048

# ====== Question API 설정 ======
MODEL=a
CHUNK_PATH=./brain_chap{chapter}.jsonl
TREE_PATH=./trees/tree_{time}_{exam_info}_{student_info}_{client_id}.json
TOP_K_CHUNK=5
EXECUTOR_WORKERS=8
DUPLICATE_THRESHOLD=0.65
NODE_MAX_DEPTH=5
ATTACHMENT_MODE=url
KEYWORD_OVERLAP_THRESHOLD=0.7
MAX_QUESTION_RETRIES=2
MAX_INSUFFICIENT_CHAIN=3

# ====== 검색 모드 설정 ======
# "rag" = RAG 시스템 (ChromaDB + 하이브리드 검색)
# "tfidf" = 기존 TF-IDF 로컬 JSONL 검색
SEARCH_MODE=rag

# ====== RAG 설정 ======
RAG_SEARCH_TOP_K=5
RAG_USE_RERANKER=true

# ====== Voice/STT 설정 ======
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
